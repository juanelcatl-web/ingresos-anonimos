{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "!/@(ads.txt|sitemap.xml|robots.txt|index.html|privacidad.html|terminos.html|adsense.html|admob.html|seo-nicho.html)",
        "destination": "/index.html"
      }
    ]
  }
}